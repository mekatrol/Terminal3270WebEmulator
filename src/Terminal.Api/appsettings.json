{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  },
  "FileLogging": {
    "Path": "/var/log/tn3270/terminal-api.log"
  },
  "Tn3270E": {
    "Host": "localhost",
    "Port": 3270,
    "TerminalType": "IBM-3279-2-E",
    "DeviceName": null,
    "ConnectionTimeoutSeconds": 30
  },
  "TerminalProxy": {
    "WebSocketPath": "/ws/terminal",
    "TerminalEndpointDisplayName": "PITS (Platform Integrated Terminal Server)",
    "SessionLifetime": "04:00:00",
    "WebSocketKeepAliveInterval": "00:00:30"
  },
  "TerminalData": {
    "DatabaseName": "TerminalApi"
  },
  "Authentication": {
    "Authority": "http://localhost:5099/mock-entra/terminaltenant/v2.0",
    "Audience": "api://terminal-api",
    "RequireHttpsMetadata": false,
    "TerminalUserRole": "Terminal.User",
    "TerminalAdminRole": "Terminal.Admin",
    "ServerAdminRole": "Server.Admin"
  },
  "AllowedHosts": "*"
}
