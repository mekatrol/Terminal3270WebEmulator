{
  "Logging": {
    "LogLevel": {
      "Default": "Debug",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.Hosting.Lifetime": "Debug",
      "Terminal": "Debug"
    }
  },
  "FileLogging": {
    "Path": "/var/log/tn3270/terminal-api.dev.log"
  },
  "Tn3270E": {
    "Host": "localhost",
    "Port": 3270,
    "TerminalType": "IBM-3279-2-E",
    "DeviceName": null,
    "ConnectionTimeoutSeconds": 30
  },
  "TerminalProxy": {
    "WebSocketPath": "/ws/terminal",
    "SessionLifetime": "04:00:00",
    "WebSocketKeepAliveInterval": "00:00:30"
  },
  "TerminalData": {
    "DatabaseName": "TerminalApiDevelopment"
  },
  "Authentication": {
    "Authority": "http://localhost:5099/mock-entra/terminaltenant/v2.0",
    "Audience": "api://terminal-api",
    "RequireHttpsMetadata": false,
    "TerminalUserRole": "Terminal.User",
    "TerminalAdminRole": "Terminal.Admin",
    "ServerAdminRole": "Server.Admin"
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "https://localhost:5173",
      "http://127.0.0.1:5173",
      "https://127.0.0.1:5173"
    ]
  }
}
